{
  "expo": {
    "name": "মণিপুরী শৈলী ",
    "slug": "MonipuriShoili",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/plogo.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/plogo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/plogo.jpg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anikcse.MonipuriShoili"
    },
    "web": {
      "favicon": "./assets/plogo.jpg"
    },
    "plugins": [
      "expo-asset",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "fbe694e1-5081-49a4-be86-4a385f3a0736"
      }
    }
  }
}
